<Window x:Class="TextConverterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Text Converter" Height="250" Width="400"
        ResizeMode="NoResize">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <Label x:Name="descriptionLabel"
               AutomationProperties.AutomationId="descriptionLabel"
               Content="Enter some text for the conversion"
               FontSize="14"
               Margin="0,0,0,8"/>
        <TextBox x:Name="inputField"
                 AutomationProperties.AutomationId="inputField"
                 FontSize="14"
                 Padding="4"
                 Margin="0,0,0,8"/>
        <Button x:Name="convertButton"
                AutomationProperties.AutomationId="convertButton"
                Content="Convert"
                FontSize="14"
                Padding="8,4"
                Margin="0,0,0,12"
                Click="ConvertButton_Click"/>
        <Label x:Name="outputLabel"
               AutomationProperties.AutomationId="outputLabel"
               FontSize="14"
               Content=""/>
    </StackPanel>
</Window>
